# -----------------------------------------------------------------------------
# Rouge Application Suite - Environment Variables
# Copy this file to `.env` in the `rouge/` repository root and fill required values.
# -----------------------------------------------------------------------------

# === Platform (required) ======================================================
# Supabase project URL.
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Platform (optional) ======================================================
# Supabase HTTP timeout in seconds (default: 30).
# SUPABASE_HTTP_TIMEOUT=30

# Verify TLS certificates for Supabase HTTP calls (default: true).
# SUPABASE_HTTP_VERIFY=true

# === Agent Provider Selection (optional) ======================================
# Global provider for agent operations (default: "claude").
# Options: "claude", "opencode"
# ROUGE_AGENT_PROVIDER=claude

# Provider for implementation step only (default: ROUGE_AGENT_PROVIDER, then "claude").
# Options: "claude", "opencode"
# ROUGE_IMPLEMENT_PROVIDER=claude

# === Claude Provider (required when using claude) =============================
# Anthropic API key used by Claude provider.
# ANTHROPIC_API_KEY=sk-your-anthropic-api-key

# Path to Claude CLI executable (default: "claude").
# CLAUDE_CODE_PATH=/usr/local/bin/claude

# Preserve project working directory in Claude bash tool calls (default: true).
# CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR=true

# Per-prompt timeout for Claude agent execution in seconds (default: 1800).
# ROUGE_PROMPT_TIMEOUT=1800

# E2B API key for cloud sandbox usage with Claude Code (only if you use E2B).
# E2B_API_KEY=

# === OpenCode Provider (optional) =============================================
# Path to OpenCode CLI executable (default: "opencode").
# OPENCODE_PATH=/usr/local/bin/opencode

# OpenCode API key (if required by your OpenCode setup).
# OPENCODE_API_KEY=your-opencode-api-key

# === Git Platform Integration (optional) ======================================
# DevSecOps platform for PR/MR steps. If unset, PR/MR creation is skipped.
# Options: "github", "gitlab"
# DEV_SEC_OPS_PLATFORM=github

# GitHub PAT for PR creation; also exported as GH_TOKEN for agent subprocesses.
# Requires `gh` CLI and repo access scope.
# GITHUB_PAT=

# GitLab PAT for MR creation.
# Requires `glab` CLI and api scope.
# GITLAB_PAT=

# === Workflow Execution (optional) ============================================
# Repository root path used by workflow steps (default: current working directory).
# REPO_PATH=/absolute/path/to/repository/root

# Working directory used for agent commands (default: current working directory).
# WORKING_DIR=/absolute/path/to/working/directory

# Default branch used by git setup steps (default: "main").
# DEFAULT_GIT_BRANCH=main

# Required to permit workflow git reset --hard during setup.
# Set to "true" only when destructive git reset behavior is acceptable.
# ROUGE_ALLOW_DESTRUCTIVE_GIT_OPS=true

# Timeout for CodeRabbit review step in seconds (default: 600).
# CODERABBIT_TIMEOUT_SECONDS=600

# Worker default per-issue workflow timeout in seconds (default: 3600).
# ROUGE_WORKFLOW_TIMEOUT_SECONDS=3600

# === Logging (optional) =======================================================
# Console log level (default: INFO).
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# ROUGE_LOG_LEVEL=INFO
